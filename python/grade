sub1=int(input("Enter subject1 marks:"))
sub2=int(input("Enter subject2 marks:"))
sub3=int(input("Enter subject3 marks:"))

if sub1<35 or sub2<35 or sub3<35 :
    print("fail")
else:
    percentage=((sub1+sub2+sub3)/300)*100
    print(percentage)
    if percentage >80 or percentage <100:
        print("grade A")
    elif percentage >60 or percentage <60:
        print("grade B")
    elif percentage >40 or percentage <60:
        print("grade c")
    else:
        print("fail")

